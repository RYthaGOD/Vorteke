# Core Solana RPC Integration (Public Mainnet Fallback Active)
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_PRIMARY=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_SECONDARY=https://api.mainnet-beta.solana.com/v2/your-api-key

# === Global Config ===
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_APP_URL=https://vortexsol.app
NEXT_PUBLIC_PROTOCOL_FEE_BPS=10

# === Monetization (Server-side) ===
VORTEX_DB_PATH=./vortex-db.json
VORTEX_JWT_SECRET=TACTICAL_RECON_ENCRYPTION_KEY
